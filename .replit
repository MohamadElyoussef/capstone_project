modules = ["python-3.12", "nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["glibcLocales"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd grad-project-main/frontend && PATH=/home/runner/workspace/node_modules/.bin:$PATH npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd grad-project-main/backend && PATH=/home/runner/workspace/.pythonlibs/bin:$PATH uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload"
waitForPort = 8000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "cd grad-project-main/backend && uvicorn app.main:app --host 0.0.0.0 --port 8000 & cd grad-project-main/frontend && npm ci --include=dev && npm run preview -- --host 0.0.0.0 --port 5000"]
build = ["bash", "-c", "cd grad-project-main/frontend && npm ci --include=dev && npm run build"]

[userenv]

[userenv.shared]
SECRET_KEY = "c162025aef6c3258145596347e2090693559a034a32a3b638fb57b035c0df4df"
